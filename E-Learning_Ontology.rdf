    <!-- http://www.example.org/elearning-ontology#LearningObjective_LinkedData -->

    <owl:NamedIndividual rdf:about="http://www.example.org/elearning-ontology#LearningObjective_LinkedData">
        <rdf:type rdf:resource="http://www.example.org/elearning-ontology#LearningObjective"/>
        <isLearningObjectiveOf rdf:resource="http://www.example.org/elearning-ontology#Course_SemanticWeb"/>
        <rdfs:comment>Students will be able to explain and apply Linked Data principles and publish RDF data according to Semantic Web best practices.</rdfs:comment>
        <rdfs:label xml:lang="en">Linked Data Principles</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/elearning-ontology#LearningObjective_OntologyDesign -->

    <owl:NamedIndividual rdf:about="http://www.example.org/elearning-ontology#LearningObjective_OntologyDesign">
        <rdf:type rdf:resource="http://www.example.org/elearning-ontology#LearningObjective"/>
        <rdfs:comment>Students will be able to design and implement well-structured OWL ontologies using Protégé, applying appropriate class hierarchies, properties, and restrictions.</rdfs:comment>
        <rdfs:label xml:lang="en">Ontology Design</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/elearning-ontology#LearningObjective_SemanticReasoning -->

    <owl:NamedIndividual rdf:about="http://www.example.org/elearning-ontology#LearningObjective_SemanticReasoning">
        <rdf:type rdf:resource="http://www.example.org/elearning-ontology#LearningObjective"/>
        <rdfs:comment>Students will be able to apply semantic reasoning using OWL reasoners such as HermiT to infer implicit knowledge from ontologies.</rdfs:comment>
        <rdfs:label xml:lang="en">Semantic Reasoning</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/elearning-ontology#Module_Week1 -->

    <owl:NamedIndividual rdf:about="http://www.example.org/elearning-ontology#Module_Week1">
        <rdf:type rdf:resource="http://www.example.org/elearning-ontology#Module"/>
        <moduleDescription>Covers the fundamental concepts of ontologies, knowledge representation, and the OWL language. Students are introduced to Protégé and basic class modelling.</moduleDescription>
        <moduleOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</moduleOrder>
        <moduleTitle>Introduction to Ontologies</moduleTitle>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/elearning-ontology#Module_Week1_SemanticWeb -->

    <owl:NamedIndividual rdf:about="http://www.example.org/elearning-ontology#Module_Week1_SemanticWeb">
        <rdf:type rdf:resource="http://www.example.org/elearning-ontology#Module"/>
        <moduleDescription>Introduces the Semantic Web stack including RDF, RDFS, and OWL. Explores Linked Data principles and the role of ontologies in enabling machine-readable knowledge on the Web.</moduleDescription>
        <moduleOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</moduleOrder>
        <moduleTitle>Foundations of the Semantic Web</moduleTitle>
    </owl:NamedIndividual>
    


