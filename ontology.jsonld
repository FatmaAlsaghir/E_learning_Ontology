  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/elearning-ontology#AcademicContent"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://www.example.org/elearning-ontology#Module"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#LearningObjective_LinkedData",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.example.org/elearning-ontology#isLearningObjectiveOf" : [ {
    "@id" : "http://www.example.org/elearning-ontology#Course_SemanticWeb"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.example.org/elearning-ontology#LearningObjective"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Students will be able to explain and apply Linked Data principles and publish RDF data according to Semantic Web best practices."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Linked Data Principles"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#LearningObjective_OntologyDesign",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.example.org/elearning-ontology#LearningObjective"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Students will be able to design and implement well-structured OWL ontologies using Protégé, applying appropriate class hierarchies, properties, and restrictions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Ontology Design"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#LearningObjective_SemanticReasoning",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.example.org/elearning-ontology#LearningObjective"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Students will be able to apply semantic reasoning using OWL reasoners such as HermiT to infer implicit knowledge from ontologies."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Semantic Reasoning"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#Module",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents a structured component of a course, used to organise content into smaller units such as topics or lessons."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Module"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/elearning-ontology#AcademicContent"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#Module_Week1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.example.org/elearning-ontology#moduleDescription" : [ {
    "@value" : "Covers the fundamental concepts of ontologies, knowledge representation, and the OWL language. Students are introduced to Protégé and basic class modelling."
  } ],
  "http://www.example.org/elearning-ontology#moduleOrder" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.example.org/elearning-ontology#moduleTitle" : [ {
    "@value" : "Introduction to Ontologies"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.example.org/elearning-ontology#Module"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#Module_Week1_SemanticWeb",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.example.org/elearning-ontology#moduleDescription" : [ {
    "@value" : "Introduces the Semantic Web stack including RDF, RDFS, and OWL. Explores Linked Data principles and the role of ontologies in enabling machine-readable knowledge on the Web."
  } ],
  "http://www.example.org/elearning-ontology#moduleOrder" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.example.org/elearning-ontology#moduleTitle" : [ {
    "@value" : "Foundations of the Semantic Web"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.example.org/elearning-ontology#Module"
  } ]
}, {
