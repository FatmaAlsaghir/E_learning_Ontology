  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents evaluative activities used to assess student performance within a course, such as assignments or exams."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Assessment"
  } ]
}, {
