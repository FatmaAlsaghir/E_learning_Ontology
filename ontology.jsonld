    "@language" : "en",
    "@value" : "submits"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/elearning-ontology#Submission"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.example.org/elearning-ontology#submittedBy"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#submittedBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Inverse of submits. Relates a Submission to the Student who submitted it. Functional: each Submission belongs to exactly one Student."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/elearning-ontology#Submission"
  } ],
