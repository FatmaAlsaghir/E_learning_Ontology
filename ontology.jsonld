  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An OWL ontology modelling the core concepts of an e-learning system,\nincluding courses, modules, assignments, student submissions, grades,\nfeedback, learning objectives, and instructor relationships. Developed\nas part of a Knowledge Engineering course project using Protégé and\nvalidated with the HermiT reasoner."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "E-Learning Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "2.0"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#AcademicContent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the organisational structure of educational content in the e-learning system, including courses and their associated modules."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Academic Content"
  } ]
}, {
  "@id" : "http://www.example.org/elearning-ontology#Assessment",
