# 
# 
# http://www.example.org/elearning-ontology#AcademicContent
<http://www.example.org/elearning-ontology#AcademicContent> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#AcademicContent> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents the organisational structure of educational content in the e-learning system, including courses and their associated modules." .
<http://www.example.org/elearning-ontology#AcademicContent> <http://www.w3.org/2000/01/rdf-schema#label> "Academic Content"@en .
# 
# http://www.example.org/elearning-ontology#Assessment
<http://www.example.org/elearning-ontology#Assessment> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Assessment> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents evaluative activities used to assess student performance within a course, such as assignments or exams." .
<http://www.example.org/elearning-ontology#Assessment> <http://www.w3.org/2000/01/rdf-schema#label> "Assessment"@en .
# 
# http://www.example.org/elearning-ontology#Assignment
<http://www.example.org/elearning-ontology#Assignment> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Assignment> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#Assessment> .
<http://www.example.org/elearning-ontology#Assignment> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents an evaluative task assigned to students within a course for completion and assessment." .
<http://www.example.org/elearning-ontology#Assignment> <http://www.w3.org/2000/01/rdf-schema#label> "Assignment"@en .
# 
# http://www.example.org/elearning-ontology#Course
<http://www.example.org/elearning-ontology#Course> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Course> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#AcademicContent> .
<http://www.example.org/elearning-ontology#Course> <http://www.w3.org/2002/07/owl#disjointWith> <http://www.example.org/elearning-ontology#LearningObjective> .
<http://www.example.org/elearning-ontology#Course> <http://www.w3.org/2002/07/owl#disjointWith> <http://www.example.org/elearning-ontology#Module> .
<http://www.example.org/elearning-ontology#Course> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents a structured unit of study within the e-learning system, consisting of modules and assignments and delivered by an instructor." .
<http://www.example.org/elearning-ontology#Course> <http://www.w3.org/2000/01/rdf-schema#label> "Course"@en .
# 
# http://www.example.org/elearning-ontology#Evaluation
<http://www.example.org/elearning-ontology#Evaluation> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Evaluation> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents the outcome of assessment processes, including results such as grades and scores assigned to student submissions." .
<http://www.example.org/elearning-ontology#Evaluation> <http://www.w3.org/2000/01/rdf-schema#label> "Evaluation"@en .
# 
# http://www.example.org/elearning-ontology#Feedback
<http://www.example.org/elearning-ontology#Feedback> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Feedback> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#Evaluation> .
<http://www.example.org/elearning-ontology#Feedback> <http://www.w3.org/2002/07/owl#disjointWith> <http://www.example.org/elearning-ontology#Grade> .
<http://www.example.org/elearning-ontology#Feedback> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents qualitative feedback provided by an instructor on a student's Submission, as distinct from the numerical score captured by Grade." .
<http://www.example.org/elearning-ontology#Feedback> <http://www.w3.org/2000/01/rdf-schema#label> "Feedback"@en .
# 
# http://www.example.org/elearning-ontology#Grade
<http://www.example.org/elearning-ontology#Grade> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Grade> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#Evaluation> .
<http://www.example.org/elearning-ontology#Grade> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents the outcome of evaluating a student's submission, expressed as a numerical score or letter grade." .
<http://www.example.org/elearning-ontology#Grade> <http://www.w3.org/2000/01/rdf-schema#label> "Grade"@en .
# 
# http://www.example.org/elearning-ontology#Instructor
<http://www.example.org/elearning-ontology#Instructor> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Instructor> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#Person> .
<http://www.example.org/elearning-ontology#Instructor> <http://www.w3.org/2002/07/owl#disjointWith> <http://www.example.org/elearning-ontology#Student> .
<http://www.example.org/elearning-ontology#Instructor> <http://www.w3.org/2000/01/rdf-schema#comment> "A person responsible for teaching one or more courses within the e-learning system." .
<http://www.example.org/elearning-ontology#Instructor> <http://www.w3.org/2000/01/rdf-schema#label> "Instructor"@en .
# 
# http://www.example.org/elearning-ontology#LateSubmission
<http://www.example.org/elearning-ontology#LateSubmission> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#LateSubmission> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#LateSubmission> <http://www.w3.org/2000/01/rdf-schema#comment> "A subclass of Submission representing any student submission whose submissionDate is later than the dueDate of the associated Assignment." .
<http://www.example.org/elearning-ontology#LateSubmission> <http://www.w3.org/2000/01/rdf-schema#label> "Late Submission"@en .
# 
# http://www.example.org/elearning-ontology#LearningObjective
<http://www.example.org/elearning-ontology#LearningObjective> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#LearningObjective> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#AcademicContent> .
<http://www.example.org/elearning-ontology#LearningObjective> <http://www.w3.org/2002/07/owl#disjointWith> <http://www.example.org/elearning-ontology#Module> .
<http://www.example.org/elearning-ontology#LearningObjective> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents a specific intended learning goal associated with a Course or Module, typically expressed as a measurable outcome statement." .
<http://www.example.org/elearning-ontology#LearningObjective> <http://www.w3.org/2000/01/rdf-schema#label> "Learning Objective"@en .
# 
# http://www.example.org/elearning-ontology#Module
<http://www.example.org/elearning-ontology#Module> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Module> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http://www.example.org/elearning-ontology#AcademicContent> .
<http://www.example.org/elearning-ontology#Module> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents a structured component of a course, used to organise content into smaller units such as topics or lessons." .
<http://www.example.org/elearning-ontology#Module> <http://www.w3.org/2000/01/rdf-schema#label> "Module"@en .
# 
# http://www.example.org/elearning-ontology#Person
<http://www.example.org/elearning-ontology#Person> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http://www.example.org/elearning-ontology#Person> <http://www.w3.org/2000/01/rdf-schema#comment> "Represents individuals participating in the e-learning system, including students and instructors." .
<http://www.example.org/elearning-ontology#Person> <http://www.w3.org/2000/01/rdf-schema#label> "Person"@en .
# 
# http://www.example.org/elearning-ontology#Student
<http://www.example.org/elearning-ontology#Student> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
