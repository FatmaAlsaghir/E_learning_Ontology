# 
# #################################################################
# #
# #    Object Properties
# #
# #################################################################
# 
# 
# http://www.example.org/elearning-ontology#enrolledIn
<http://www.example.org/elearning-ontology#enrolledIn> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#enrolledIn> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#hasStudent> .
<http://www.example.org/elearning-ontology#enrolledIn> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Student> .
<http://www.example.org/elearning-ontology#enrolledIn> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#enrolledIn> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Student to the Course they are enrolled in." .
<http://www.example.org/elearning-ontology#enrolledIn> <http://www.w3.org/2000/01/rdf-schema#label> "enrolled in"@en .
# 
# http://www.example.org/elearning-ontology#hasAssignment
<http://www.example.org/elearning-ontology#hasAssignment> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasAssignment> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#isAssignmentOf> .
<http://www.example.org/elearning-ontology#hasAssignment> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#hasAssignment> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Assignment> .
<http://www.example.org/elearning-ontology#hasAssignment> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Course to its Assignments." .
<http://www.example.org/elearning-ontology#hasAssignment> <http://www.w3.org/2000/01/rdf-schema#label> "has assignment"@en .
# 
# http://www.example.org/elearning-ontology#hasFeedback
<http://www.example.org/elearning-ontology#hasFeedback> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasFeedback> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#isFeedbackFor> .
<http://www.example.org/elearning-ontology#hasFeedback> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#hasFeedback> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Feedback> .
<http://www.example.org/elearning-ontology#hasFeedback> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Submission to the qualitative Feedback provided by the instructor upon evaluation." .
<http://www.example.org/elearning-ontology#hasFeedback> <http://www.w3.org/2000/01/rdf-schema#label> "has feedback"@en .
# 
# http://www.example.org/elearning-ontology#hasGrade
<http://www.example.org/elearning-ontology#hasGrade> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasGrade> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#FunctionalProperty> .
<http://www.example.org/elearning-ontology#hasGrade> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#hasGrade> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Grade> .
<http://www.example.org/elearning-ontology#hasGrade> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Submission to its Grade. Functional: each Submission has at most one Grade." .
<http://www.example.org/elearning-ontology#hasGrade> <http://www.w3.org/2000/01/rdf-schema#label> "has grade"@en .
# 
# http://www.example.org/elearning-ontology#hasLearningObjective
<http://www.example.org/elearning-ontology#hasLearningObjective> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasLearningObjective> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#isLearningObjectiveOf> .
<http://www.example.org/elearning-ontology#hasLearningObjective> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#hasLearningObjective> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#LearningObjective> .
<http://www.example.org/elearning-ontology#hasLearningObjective> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Course to its associated LearningObjective individuals, representing the intended learning goals of the course." .
<http://www.example.org/elearning-ontology#hasLearningObjective> <http://www.w3.org/2000/01/rdf-schema#label> "has learning objective"@en .
# 
# http://www.example.org/elearning-ontology#hasModule
<http://www.example.org/elearning-ontology#hasModule> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasModule> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#isModuleOf> .
<http://www.example.org/elearning-ontology#hasModule> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#hasModule> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Module> .
<http://www.example.org/elearning-ontology#hasModule> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Course to its Modules." .
<http://www.example.org/elearning-ontology#hasModule> <http://www.w3.org/2000/01/rdf-schema#label> "has module"@en .
# 
# http://www.example.org/elearning-ontology#hasPrerequisite
<http://www.example.org/elearning-ontology#hasPrerequisite> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasPrerequisite> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#TransitiveProperty> .
<http://www.example.org/elearning-ontology#hasPrerequisite> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#hasPrerequisite> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#hasPrerequisite> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Course to its prerequisite Course(s). Transitive: if A requires B and B requires C, then A requires C." .
<http://www.example.org/elearning-ontology#hasPrerequisite> <http://www.w3.org/2000/01/rdf-schema#label> "has prerequisite"@en .
# 
# http://www.example.org/elearning-ontology#hasStudent
<http://www.example.org/elearning-ontology#hasStudent> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasStudent> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#hasStudent> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Student> .
<http://www.example.org/elearning-ontology#hasStudent> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of enrolledIn. Relates a Course to its enrolled Students." .
<http://www.example.org/elearning-ontology#hasStudent> <http://www.w3.org/2000/01/rdf-schema#label> "has student"@en .
# 
# http://www.example.org/elearning-ontology#hasSubmission
<http://www.example.org/elearning-ontology#hasSubmission> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#hasSubmission> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#submissionFor> .
<http://www.example.org/elearning-ontology#hasSubmission> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Assignment> .
<http://www.example.org/elearning-ontology#hasSubmission> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#hasSubmission> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of submissionFor. Relates an Assignment to its Submissions." .
<http://www.example.org/elearning-ontology#hasSubmission> <http://www.w3.org/2000/01/rdf-schema#label> "has submission"@en .
# 
# http://www.example.org/elearning-ontology#isAssignmentOf
<http://www.example.org/elearning-ontology#isAssignmentOf> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#isAssignmentOf> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Assignment> .
<http://www.example.org/elearning-ontology#isAssignmentOf> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#isAssignmentOf> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of hasAssignment. Relates an Assignment back to the Course it belongs to." .
<http://www.example.org/elearning-ontology#isAssignmentOf> <http://www.w3.org/2000/01/rdf-schema#label> "is assignment of"@en .
# 
# http://www.example.org/elearning-ontology#isFeedbackFor
<http://www.example.org/elearning-ontology#isFeedbackFor> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#isFeedbackFor> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Feedback> .
<http://www.example.org/elearning-ontology#isFeedbackFor> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#isFeedbackFor> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of hasFeedback. Relates a Feedback individual back to the Submission it was given for." .
<http://www.example.org/elearning-ontology#isFeedbackFor> <http://www.w3.org/2000/01/rdf-schema#label> "is feedback for"@en .
# 
# http://www.example.org/elearning-ontology#isLearningObjectiveOf
<http://www.example.org/elearning-ontology#isLearningObjectiveOf> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#isLearningObjectiveOf> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#LearningObjective> .
<http://www.example.org/elearning-ontology#isLearningObjectiveOf> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#isLearningObjectiveOf> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of hasLearningObjective. Relates a LearningObjective back to its Course." .
<http://www.example.org/elearning-ontology#isLearningObjectiveOf> <http://www.w3.org/2000/01/rdf-schema#label> "is learning objective of"@en .
# 
# http://www.example.org/elearning-ontology#isModuleOf
<http://www.example.org/elearning-ontology#isModuleOf> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#isModuleOf> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Module> .
<http://www.example.org/elearning-ontology#isModuleOf> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#isModuleOf> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of hasModule. Relates a Module back to the Course it belongs to." .
<http://www.example.org/elearning-ontology#isModuleOf> <http://www.w3.org/2000/01/rdf-schema#label> "is module of"@en .
# 
# http://www.example.org/elearning-ontology#isTaughtBy
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#teaches> .
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#FunctionalProperty> .
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Instructor> .
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of teaches. Relates a Course to its Instructor. Functional: each Course has at most one Instructor." .
<http://www.example.org/elearning-ontology#isTaughtBy> <http://www.w3.org/2000/01/rdf-schema#label> "is taught by"@en .
# 
# http://www.example.org/elearning-ontology#submissionFor
<http://www.example.org/elearning-ontology#submissionFor> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#submissionFor> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#FunctionalProperty> .
<http://www.example.org/elearning-ontology#submissionFor> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#submissionFor> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Assignment> .
<http://www.example.org/elearning-ontology#submissionFor> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Submission to the Assignment it was submitted for. Functional: each Submission targets exactly one Assignment." .
<http://www.example.org/elearning-ontology#submissionFor> <http://www.w3.org/2000/01/rdf-schema#label> "submission for"@en .
# 
# http://www.example.org/elearning-ontology#submits
<http://www.example.org/elearning-ontology#submits> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#submits> <http://www.w3.org/2002/07/owl#inverseOf> <http://www.example.org/elearning-ontology#submittedBy> .
<http://www.example.org/elearning-ontology#submits> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Student> .
<http://www.example.org/elearning-ontology#submits> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#submits> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates a Student to the Submission they submitted." .
<http://www.example.org/elearning-ontology#submits> <http://www.w3.org/2000/01/rdf-schema#label> "submits"@en .
# 
# http://www.example.org/elearning-ontology#submittedBy
<http://www.example.org/elearning-ontology#submittedBy> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#submittedBy> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#FunctionalProperty> .
<http://www.example.org/elearning-ontology#submittedBy> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Submission> .
<http://www.example.org/elearning-ontology#submittedBy> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Student> .
<http://www.example.org/elearning-ontology#submittedBy> <http://www.w3.org/2000/01/rdf-schema#comment> "Inverse of submits. Relates a Submission to the Student who submitted it. Functional: each Submission belongs to exactly one Student." .
<http://www.example.org/elearning-ontology#submittedBy> <http://www.w3.org/2000/01/rdf-schema#label> "submitted by"@en .
# 
# http://www.example.org/elearning-ontology#teaches
<http://www.example.org/elearning-ontology#teaches> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://www.example.org/elearning-ontology#teaches> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/elearning-ontology#Instructor> .
<http://www.example.org/elearning-ontology#teaches> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.example.org/elearning-ontology#Course> .
<http://www.example.org/elearning-ontology#teaches> <http://www.w3.org/2000/01/rdf-schema#comment> "Relates an Instructor to the Course they teach." .
<http://www.example.org/elearning-ontology#teaches> <http://www.w3.org/2000/01/rdf-schema#label> "teaches"@en .
